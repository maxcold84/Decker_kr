{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decker.example/resources/ko-ui/strings.schema.json",
  "title": "Decker Korean UI string inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "owner", "source"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_.\\[\\]-]+$"
          },
          "kind": {
            "enum": [
              "fixed-ui-label",
              "fixed-ui-format",
              "internal-token",
              "dynamic-user-content",
              "diagnostic"
            ]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "ko": {
            "type": "string",
            "minLength": 1
          },
          "preserve": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "enum": ["fixed-ui-label", "fixed-ui-format"]
                }
              },
              "required": ["kind"]
            },
            "then": {
              "required": ["ko"],
              "not": {
                "required": ["preserve"]
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "enum": ["internal-token", "dynamic-user-content"]
                }
              },
              "required": ["kind"]
            },
            "then": {
              "required": ["preserve"],
              "properties": {
                "preserve": {
                  "const": true
                }
              },
              "not": {
                "required": ["ko"]
              }
            }
          }
        ]
      }
    }
  }
}
